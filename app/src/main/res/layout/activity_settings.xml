<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B3A6B"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dark Mode"
                android:textSize="16sp"
                android:textColor="#333333"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchDarkMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Timer Duration"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn15s"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="15s"
                android:backgroundTint="#1B3A6B"
                android:textColor="#FFFFFF"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btn30s"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="30s"
                android:backgroundTint="#F5A623"
                android:textColor="#1B3A6B"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btn60s"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="60s"
                android:backgroundTint="#30B0C7"
                android:textColor="#1B3A6B"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btn90s"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="90s"
                android:backgroundTint="#AAC4EE"
                android:textColor="#1B3A6B"
                android:layout_margin="4dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Version"
                android:textSize="16sp"
                android:textColor="#333333"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0.0"
                android:textSize="16sp"
                android:textColor="#888888"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnClearAllHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear All History"
            android:backgroundTint="#FFEEEE"
            android:textColor="#AA0000"
            android:textSize="16sp"
            android:padding="14dp"/>

        <Button
            android:id="@+id/btnGoHomeSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go Home"
            android:backgroundTint="#1B3A6B"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="14dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</LinearLayout>