<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B3A6B"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="QuizApp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnHistoryNav"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="History"
                android:backgroundTint="#2A4A7B"
                android:textColor="#AAC4EE"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnLeaderboard"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Leaderboard"
                android:backgroundTint="#2A4A7B"
                android:textColor="#AAC4EE"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Settings"
                android:backgroundTint="#2A4A7B"
                android:textColor="#AAC4EE"
                android:textSize="12sp"/>

    </LinearLayout>
</LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select a Category"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1B3A6B"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B3A6B"
                android:layout_marginBottom="12dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="24dp">

                <Button android:id="@+id/btnScience"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="Science"
                    android:backgroundTint="#E8EEF8"
                    android:textColor="#1B3A6B"
                    android:layout_margin="4dp"/>

                <Button android:id="@+id/btnMath"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="Math"
                    android:backgroundTint="#E8EEF8"
                    android:textColor="#1B3A6B"
                    android:layout_margin="4dp"/>

                <Button android:id="@+id/btnCategoryHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="History"
                    android:backgroundTint="#E8EEF8"
                    android:textColor="#1B3A6B"
                    android:layout_margin="4dp"/>

                <Button android:id="@+id/btnGeneral"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="General"
                    android:backgroundTint="#E8EEF8"
                    android:textColor="#1B3A6B"
                    android:layout_margin="4dp"/>

            </GridLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Difficulty"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B3A6B"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <Button android:id="@+id/btnEasy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Easy"
                    android:backgroundTint="#E6F7EE"
                    android:textColor="#1a7a40"
                    android:layout_margin="4dp"/>

                <Button android:id="@+id/btnMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Medium"
                    android:backgroundTint="#FFF3E0"
                    android:textColor="#a05800"
                    android:layout_margin="4dp"/>

                <Button android:id="@+id/btnHard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hard"
                    android:backgroundTint="#FFEEEE"
                    android:textColor="#aa0000"
                    android:layout_margin="4dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnStartQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Quiz"
                android:backgroundTint="#1B3A6B"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="16dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnExit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Exit"
                android:backgroundTint="#FFEEEE"
                android:textColor="#AA0000"
                android:textSize="16sp"
                android:padding="14dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>